*.pyc


# 네이버 쇼핑 키워드 관찰 실행 데이터
# keywordObservation/data 전체를 제외하는 기존 규칙이 있다면
# .gitignore의 마지막 부분에 아래 예외를 추가합니다.


!keywordObservation/data/
keywordObservation/data/*

# 코드와 함께 관리할 설정·사전·입력양식만 다시 포함
!keywordObservation/data/keyword_observation_settings.json
!keywordObservation/data/reference_dictionary.json
!keywordObservation/data/keyword_relationships.json
!keywordObservation/data/naver_commerce_credentials.example.json

!keywordObservation/data/keyword_inputs/
keywordObservation/data/keyword_inputs/*
!keywordObservation/data/keyword_inputs/키워드_입력_양식.xlsx

!keywordObservation/data/optimization_inputs/
keywordObservation/data/optimization_inputs/*
!keywordObservation/data/optimization_inputs/사용방법.txt

# 인증정보는 반드시 제외
keywordObservation/data/private/

# 네이버 쇼핑 관찰 운영자료
keywordObservation/data/naver_shopping_observations.jsonl
keywordObservation/data/reference_candidate_registry.json
keywordObservation/data/dictionary_collection_history.jsonl
keywordObservation/data/unresolved_keywords.jsonl

# 태그·가공 운영자료
keywordObservation/data/naver_tag_observations.jsonl
keywordObservation/data/tag_restriction_observations.jsonl
keywordObservation/data/manual_tag_usage_records.jsonl
keywordObservation/data/optimization_records.jsonl
keywordObservation/data/optimization_import_history.jsonl
keywordObservation/data/tag_registry.json

# 읽기용 파일과 백업
keywordObservation/data/readable/
keywordObservation/data/backup/